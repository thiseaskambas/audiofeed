# Audiofeed Python Microservice — env template
# Copy to .env and fill in values.

PROVIDER=openai
# PROVIDER=openai or PROVIDER=google

# --- OpenAI (required if PROVIDER=openai) ---
OPENAI_API_KEY=sk-...

# --- Google (required if PROVIDER=google) ---
GOOGLE_API_KEY=AIza...
GOOGLE_APPLICATION_CREDENTIALS=/app/google-credentials.json

# --- Sevalla S3 ---
S3_ENDPOINT_URL=https://your-bucket.sevalla.com
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=audiofeed-audio

# --- Shared secret (Node.js sends this in X-API-Key header) ---
API_SECRET=generate-a-random-string
