# Audiofeed env template
# Copy to .env and fill in values.

# Providers can be configured independently.
LLM_PROVIDER=openai
TTS_PROVIDER=openai

# --- OpenAI (required if LLM_PROVIDER=openai or TTS_PROVIDER=openai) ---
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=tts-1-hd

# --- Google (required if LLM_PROVIDER=google or TTS_PROVIDER=google) ---
GOOGLE_API_KEY=AIza...
GOOGLE_LLM_MODEL=gemini-2.5-flash
GOOGLE_TTS_MODEL=gemini-2.5-flash-preview-tts
# Required only for notebooklm_podcast
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
NOTEBOOKLM_PROJECT_ID=your-gcp-project-id
NOTEBOOKLM_LOCATION=global
NOTEBOOKLM_DAILY_LIMIT=20

# --- Sevalla S3 ---
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://<bucket>.sevalla.storage
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=audiofeed-audio

# --- Shared secret (Node.js sends this in X-API-Key header) ---
API_SECRET=generate-a-random-string

# --- Redis (required) ---
REDIS_URL=redis://localhost:6379

# --- Server (optional) ---
PORT=8020
