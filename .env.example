# Audiofeed Python Microservice — env template
# Copy to .env and fill in values.

PROVIDER=openai
# PROVIDER=openai or PROVIDER=google

# --- OpenAI (required if PROVIDER=openai) ---
OPENAI_API_KEY=sk-...

# --- Google (required if PROVIDER=google) ---
GOOGLE_API_KEY=AIza...
GOOGLE_APPLICATION_CREDENTIALS=app/utils/credentials.json

# --- Sevalla S3 ---
S3_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://<bucket>.sevalla.storage
S3_ACCESS_KEY_ID=...
S3_SECRET_ACCESS_KEY=...
S3_BUCKET_NAME=audiofeed-audio

# --- Shared secret (Node.js sends this in X-API-Key header) ---
API_SECRET=generate-a-random-string

# --- Redis (required) ---
REDIS_URL=redis://localhost:6379

# --- Server (optional) ---
PORT=8050
